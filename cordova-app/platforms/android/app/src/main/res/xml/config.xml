<?xml version='1.0' encoding='utf-8'?>
<widget id="com.jinhuohuo.app" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>金火银火</name>
    <description>
        金火银火星球跟单平台 - 专业的交易跟单平台
    </description>
    <author email="support@jinhuohuo.coze.site" href="https://jinhuohuo.coze.site">
        金火银火
    </author>
    <content src="https://jinhuohuo.coze.site" />
    <allow-navigation href="https://jinhuohuo.coze.site" />
    <allow-navigation href="https://*.coze.site" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-intent href="tel:*" />
    <allow-intent href="sms:*" />
    <allow-intent href="mailto:*" />
    <allow-intent href="geo:*" />
    <icon density="ldpi" src="res/icons/ldpi.png" />
    <icon density="mdpi" src="res/icons/mdpi.png" />
    <icon density="hdpi" src="res/icons/hdpi.png" />
    <icon density="xhdpi" src="res/icons/xhdpi.png" />
    <icon density="xxhdpi" src="res/icons/xxhdpi.png" />
    <icon density="xxxhdpi" src="res/icons/xxxhdpi.png" />
    <preference name="loglevel" value="DEBUG" />
    <preference name="DisallowOverscroll" value="true" />
    <preference name="Orientation" value="portrait" />
    <preference name="BackgroundColor" value="0xffffffff" />
    <preference name="Fullscreen" value="false" />
    <preference name="StatusBarOverlaysWebView" value="true" />
    <preference name="StatusBarBackgroundColor" value="#7c3aed" />
    <preference name="android-minSdkVersion" value="22" />
    <preference name="android-targetSdkVersion" value="34" />
    <preference name="android-installLocation" value="auto" />
</widget>
