<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- 允许明文流量（开发环境） -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    
    <!-- 生产环境域名配置 -->
    <domain-config>
        <domain includeSubdomains="true">miaolegemiao.com</domain>
        <domain includeSubdomains="true">dev.coze.site</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>
</network-security-config>
