    "x-next-cache-tags": "_N_T_/layout,_N_T_/admin/layout,_N_T_/admin/challenge/layout,_N_T_/admin/challenge/page,_N_T_/admin/challenge"
  },
  "segmentPaths": [
    "/_tree",
